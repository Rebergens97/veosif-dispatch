<div class="max-w-4xl mx-auto">
    <div class="mb-6 text-center">
        <h2 class="text-2xl font-bold text-gray-900 dark:text-white">Choose Your Plan</h2>
        <p class="text-gray-500 dark:text-gray-400 mt-1">Select the plan that fits your operations. You can upgrade anytime.</p>

        {{!-- Billing cycle toggle --}}
        <div class="flex items-center justify-center mt-4 space-x-3">
            <span class="text-sm font-medium {{if this.isMonthly 'text-gray-900 dark:text-white' 'text-gray-500 dark:text-gray-400'}}">Monthly</span>
            <button
                type="button"
                class="relative inline-flex h-6 w-11 flex-shrink-0 cursor-pointer rounded-full border-2 border-transparent transition-colors duration-200 ease-in-out focus:outline-none
                    {{if this.isMonthly 'bg-gray-300 dark:bg-gray-600' 'bg-teal-500'}}"
                {{on "click" this.toggleBillingCycle}}
            >
                <span class="pointer-events-none inline-block h-5 w-5 transform rounded-full bg-white shadow ring-0 transition duration-200 ease-in-out
                    {{if this.isMonthly 'translate-x-0' 'translate-x-5'}}"></span>
            </button>
            <span class="text-sm font-medium {{if (not this.isMonthly) 'text-gray-900 dark:text-white' 'text-gray-500 dark:text-gray-400'}}">
                Yearly
                <span class="ml-1 inline-flex items-center px-1.5 py-0.5 rounded text-xs font-medium bg-teal-100 dark:bg-teal-900 text-teal-700 dark:text-teal-300">
                    Save 20%
                </span>
            </span>
        </div>
    </div>

    {{!-- Plan cards --}}
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-6">
        {{#each this.plans as |plan|}}
            <button
                type="button"
                class="relative rounded-xl border-2 p-6 text-left transition-all duration-200 hover:shadow-lg
                    {{if (eq this.selectedPlan plan.id)
                        'border-teal-500 bg-teal-50 dark:bg-teal-900/20 shadow-lg'
                        (if plan.recommended
                            'border-teal-200 dark:border-teal-800 bg-white dark:bg-gray-800 hover:border-teal-300'
                            'border-gray-200 dark:border-gray-700 bg-white dark:bg-gray-800 hover:border-gray-300 dark:hover:border-gray-600')}}"
                {{on "click" (fn this.selectPlan plan.id)}}
            >
                {{!-- Recommended badge --}}
                {{#if plan.recommended}}
                    <div class="absolute -top-3 left-1/2 transform -translate-x-1/2">
                        <span class="inline-flex items-center px-3 py-0.5 rounded-full text-xs font-semibold bg-teal-500 text-white shadow">
                            Recommended
                        </span>
                    </div>
                {{/if}}

                {{!-- Selected indicator --}}
                {{#if (eq this.selectedPlan plan.id)}}
                    <div class="absolute top-3 right-3">
                        <div class="w-6 h-6 rounded-full bg-teal-500 flex items-center justify-center">
                            <FaIcon @icon="check" @size="xs" class="text-white" />
                        </div>
                    </div>
                {{/if}}

                <h3 class="text-lg font-bold text-gray-900 dark:text-white">{{plan.name}}</h3>
                <p class="text-sm text-gray-500 dark:text-gray-400 mb-4">{{plan.description}}</p>

                {{!-- Price --}}
                <div class="mb-4">
                    <span class="text-3xl font-extrabold text-gray-900 dark:text-white">
                        ${{if this.isMonthly plan.monthlyPrice plan.yearlyPrice}}
                    </span>
                    <span class="text-gray-500 dark:text-gray-400">/mo</span>
                    {{#unless this.isMonthly}}
                        <span class="block text-xs text-gray-400 dark:text-gray-500 mt-1">
                            billed yearly
                        </span>
                    {{/unless}}
                </div>

                {{!-- Features --}}
                <ul class="space-y-2">
                    {{#each plan.features as |feature|}}
                        <li class="flex items-center text-sm">
                            {{#if feature.included}}
                                <FaIcon @icon="check" @size="xs" class="text-teal-500 mr-2 flex-shrink-0" />
                                <span class="text-gray-700 dark:text-gray-300">{{feature.label}}</span>
                            {{else}}
                                <FaIcon @icon="minus" @size="xs" class="text-gray-300 dark:text-gray-600 mr-2 flex-shrink-0" />
                                <span class="text-gray-400 dark:text-gray-500">{{feature.label}}</span>
                            {{/if}}
                        </li>
                    {{/each}}
                </ul>
            </button>
        {{/each}}
    </div>

    {{!-- Free trial option --}}
    <div class="bg-white dark:bg-gray-800 rounded-xl shadow p-4 mb-6">
        <label class="flex items-center cursor-pointer">
            <input
                type="checkbox"
                checked={{this.isTrial}}
                class="form-checkbox h-4 w-4 text-teal-500 rounded border-gray-300 dark:border-gray-600"
                {{on "change" this.toggleTrial}}
            />
            <span class="ml-3">
                <span class="text-sm font-medium text-gray-900 dark:text-white">Start with a 14-day free trial</span>
                <span class="block text-xs text-gray-500 dark:text-gray-400">No credit card required. Full access to all features of your selected plan.</span>
            </span>
        </label>
    </div>

    {{!-- Navigation --}}
    <div class="flex items-center justify-between">
        <Button
            @type="default"
            @icon="arrow-left"
            @iconPrefix="fas"
            @text="Back"
            @onClick={{this.goBack}}
        />
        <Button
            @type="primary"
            @icon="arrow-right"
            @iconPrefix="fas"
            @text="Continue"
            @onClick={{this.continueSetup}}
            @disabled={{not this.selectedPlan}}
        />
    </div>
</div>
