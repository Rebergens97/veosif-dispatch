<div class="p-5 h-full flex flex-col">
    {{!-- Header --}}
    <div class="flex items-center justify-between mb-5">
        <div>
            <h3 class="text-base font-semibold text-gray-900 dark:text-white">Platform Overview</h3>
            <p class="text-xs text-gray-500 dark:text-gray-400 mt-0.5">{{this.companyName}}</p>
        </div>
        <div class="w-10 h-10 rounded-xl bg-teal-100 dark:bg-teal-900/30 flex items-center justify-center">
            <FaIcon @icon="chart-simple" class="text-teal-600 dark:text-teal-400" />
        </div>
    </div>

    {{#if this.isLoading}}
        <div class="flex-1 flex items-center justify-center">
            <Spinner />
        </div>
    {{else}}
        <div class="flex-1 space-y-3">
            {{!-- Organizations (super admin only) --}}
            {{#if this.isSuperAdmin}}
                <div class="flex items-center justify-between p-3 rounded-xl bg-teal-50 dark:bg-teal-900/20">
                    <div class="flex items-center space-x-3">
                        <div class="w-8 h-8 rounded-lg bg-teal-500 flex items-center justify-center">
                            <FaIcon @icon="building" @size="xs" class="text-white" />
                        </div>
                        <span class="text-sm font-medium text-gray-700 dark:text-gray-300">Organizations</span>
                    </div>
                    <span class="text-xl font-bold text-teal-600 dark:text-teal-400">{{this.stats.organizations}}</span>
                </div>
            {{/if}}

            {{!-- Users / Dispatchers --}}
            <div class="flex items-center justify-between p-3 rounded-xl bg-blue-50 dark:bg-blue-900/20">
                <div class="flex items-center space-x-3">
                    <div class="w-8 h-8 rounded-lg bg-blue-500 flex items-center justify-center">
                        <FaIcon @icon="users" @size="xs" class="text-white" />
                    </div>
                    <span class="text-sm font-medium text-gray-700 dark:text-gray-300">{{if this.isSuperAdmin "Total Users" "Dispatchers"}}</span>
                </div>
                <span class="text-xl font-bold text-blue-600 dark:text-blue-400">{{this.stats.users}}</span>
            </div>

            {{!-- Drivers --}}
            <div class="flex items-center justify-between p-3 rounded-xl bg-purple-50 dark:bg-purple-900/20">
                <div class="flex items-center space-x-3">
                    <div class="w-8 h-8 rounded-lg bg-purple-500 flex items-center justify-center">
                        <FaIcon @icon="id-card" @size="xs" class="text-white" />
                    </div>
                    <span class="text-sm font-medium text-gray-700 dark:text-gray-300">Drivers</span>
                </div>
                <span class="text-xl font-bold text-purple-600 dark:text-purple-400">{{this.stats.drivers}}</span>
            </div>

            {{!-- Orders this week --}}
            <div class="flex items-center justify-between p-3 rounded-xl bg-orange-50 dark:bg-orange-900/20">
                <div class="flex items-center space-x-3">
                    <div class="w-8 h-8 rounded-lg bg-orange-500 flex items-center justify-center">
                        <FaIcon @icon="box" @size="xs" class="text-white" />
                    </div>
                    <span class="text-sm font-medium text-gray-700 dark:text-gray-300">Orders This Week</span>
                </div>
                <span class="text-xl font-bold text-orange-600 dark:text-orange-400">{{this.stats.ordersThisWeek}}</span>
            </div>
        </div>
    {{/if}}

    {{!-- Footer --}}
    <div class="mt-4 pt-3 border-t border-gray-100 dark:border-gray-700">
        <p class="text-xs text-center text-gray-400 dark:text-gray-500">VEOSIF Dispatch v0.7.30</p>
    </div>
</div>
